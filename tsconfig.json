{
  "compilerOptions": {
    "baseUrl": "src",
    "isolatedModules": true,
    "jsx": "react-jsxdev",
    "jsxImportSource": "@emotion/react",
    "moduleResolution": "node",
    "noEmit": true,
    "paths": {
      "@assets": ["assets"],
      "@components": ["components"],
      "@constants": ["constants"],
      "@data": ["data"],
      "@pages": ["pages"]
    },
    "resolveJsonModule": true,
    "strict": true,
    "target": "es6"
  },
  "include": ["src/**/*"]
}
